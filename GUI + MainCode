    NOT_REQUIRED = "NOT_REQUIRED"
    PENDING = "PENDING"
    PAID = "PAID"
    FAILED = "FAILED"
    REFUNDED = "REFUNDED"


class PaymentPurpose(Enum):
    """
    PaymentPurpose explains why a payment was created.

    Purpose:
    - BOOKING_FEE is used for paid facility bookings.
